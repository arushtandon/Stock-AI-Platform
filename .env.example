# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stock_ai
# Or SQLite for dev: sqlite:///./stock_ai.db

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Frontend API URL (for Docker/cloud builds; e.g. https://api.your-domain.com)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: Premium data source API keys (demo data used if not set)
# DANELFIN_API_KEY=
# SEEKING_ALPHA_API_KEY=
# INVESTING_PRO_API_KEY=
# TRADINGVIEW_API_KEY=

# Scoring weights (defaults: 0.35, 0.35, 0.20, 0.10)
# WEIGHT_FUNDAMENTAL=0.35
# WEIGHT_TECHNICAL=0.35
# WEIGHT_ANALYST=0.20
# WEIGHT_SENTIMENT=0.10

# Filters
# MIN_MARKET_CAP=1000000000
# TOP_N_RECOMMENDATIONS=20
